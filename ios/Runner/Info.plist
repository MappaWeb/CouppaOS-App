<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Couppa Mini</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>couppa_mini</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Privacy usage descriptions -->
	<key>NSCameraUsageDescription</key>
	<string>Ứng dụng cần truy cập camera để chụp ảnh, quay video và quét mã.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Ứng dụng cần truy cập micro để ghi âm trong video và cuộc gọi.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Ứng dụng cần truy cập thư viện ảnh để chọn ảnh và video.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Ứng dụng cần quyền lưu ảnh và video vào thư viện của bạn.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Ứng dụng sử dụng Face ID để bảo mật dữ liệu đăng nhập.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>Ứng dụng sử dụng dữ liệu để phân tích và cải thiện trải nghiệm.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Ứng dụng cần truy cập mạng nội bộ để kết nối với các thiết bị xung quanh.</string>

	<!-- Background modes (Firebase Messaging, audio playback, background fetch) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>audio</string>
	</array>

	<!-- App Transport Security: cho phép WebView load nội dung HTTP nếu cần -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
		<key>NSAllowsArbitraryLoadsForMedia</key>
		<true/>
	</dict>

	<!-- url_launcher: các scheme app cần mở -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>http</string>
		<string>https</string>
		<string>tel</string>
		<string>mailto</string>
		<string>sms</string>
		<string>itms-apps</string>
	</array>

	<!-- Không sử dụng mã hoá phi tiêu chuẩn (tránh prompt khi nộp store) -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Firebase Messaging: cho phép FlutterFire SDK swizzle để xử lý APNs token -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<true/>

	<!-- io.flutter plugins yêu cầu io.flutter.embedded_views_preview = YES -->
	<key>io.flutter.embedded_views_preview</key>
	<true/>
</dict>
</plist>
